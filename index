<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>WHEN AI GETS HANDS. — ローカル × ブラウザ × エージェント × 横断自動化</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@500;700;800;900&family=Noto+Sans+JP:wght@400;500;700;900&display=swap" rel="stylesheet">
<style>
:root{
  --bg:#0A0C16;
  --panel:#11131F;
  --panel2:#161927;
  --ink:#F1F2F7;
  --sub:#8F92A6;
  --line:#222536;
  --local:#FFB36B;
  --browser:#5EE0C8;
  --agent:#8E9BFF;
  --cross:#E985D8;
  --ease:cubic-bezier(.22,1,.36,1);
}
*{margin:0;padding:0;box-sizing:border-box;}
html{scroll-behavior:smooth;}
body{
  font-family:'Noto Sans JP',sans-serif;
  background:var(--bg);color:var(--ink);
  line-height:1.8;overflow-x:hidden;
  -webkit-font-smoothing:antialiased;
}
.en{font-family:'Inter','Noto Sans JP',sans-serif;letter-spacing:-.02em;}
svg.ic{width:22px;height:22px;fill:none;stroke:currentColor;stroke-width:1.8;stroke-linecap:round;stroke-linejoin:round;flex-shrink:0;}
::selection{background:var(--agent);color:#0A0C16;}
/* ── progress / nav ── */
#progress{position:fixed;top:0;left:0;height:3px;width:0;z-index:999;background:linear-gradient(90deg,var(--local),var(--browser),var(--agent),var(--cross));transition:width .1s linear;}
nav{position:sticky;top:0;z-index:900;background:rgba(10,12,22,.82);backdrop-filter:blur(14px);border-bottom:1px solid var(--line);}
.nav-in{max-width:1200px;margin:0 auto;display:flex;align-items:center;gap:6px;padding:16px 28px;}
.nav-brand{font-family:'Inter';font-weight:800;font-size:13px;letter-spacing:.12em;margin-right:auto;}
nav a{color:var(--sub);text-decoration:none;font-size:11px;font-weight:700;letter-spacing:.08em;padding:6px 11px;border-radius:99px;transition:.3s var(--ease);}
nav a:hover{color:var(--ink);background:#1C1F30;}
@media(max-width:820px){nav a{display:none}}
/* ── hero ── */
.hero{position:relative;max-width:1200px;margin:0 auto;padding:120px 28px 60px;}
.glow{position:absolute;border-radius:50%;filter:blur(120px);opacity:.32;z-index:0;pointer-events:none;}
.glow1{width:460px;height:460px;background:#5A2BD9;top:-160px;right:-80px;animation:drift 13s ease-in-out infinite;}
.glow2{width:380px;height:380px;background:#0E5F55;bottom:-160px;left:-120px;animation:drift 13s ease-in-out infinite reverse;}
@keyframes drift{0%,100%{transform:translate(0,0)}50%{transform:translate(-40px,30px)}}
.hero>*{position:relative;z-index:1;}
.eyebrow{display:flex;align-items:center;gap:14px;font-family:'Inter';font-size:11px;font-weight:700;letter-spacing:.3em;color:var(--sub);margin-bottom:36px;}
.eyebrow::before{content:"";width:42px;height:1px;background:var(--agent);}
.hero h1{font-family:'Inter';font-weight:900;font-size:clamp(44px,9vw,118px);line-height:1.0;letter-spacing:-.03em;}
.hero h1 .l2{display:block;background:linear-gradient(92deg,var(--local) 0%,var(--browser) 33%,var(--agent) 66%,var(--cross) 100%);-webkit-background-clip:text;background-clip:text;color:transparent;}
.hero .jp{margin-top:34px;font-size:clamp(14px,1.8vw,17px);font-weight:700;line-height:2.1;}
.hero .jp small{display:block;font-weight:400;color:var(--sub);font-size:.82em;margin-top:8px;max-width:640px;}
/* concept strip */
.concepts{display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:14px;margin-top:54px;}
.concept{border:1px solid var(--line);background:var(--panel);border-radius:20px;padding:24px 22px;transition:.4s var(--ease);position:relative;overflow:hidden;}
.concept::after{content:"";position:absolute;left:0;top:0;bottom:0;width:3px;}
.concept.k1::after{background:var(--local);}
.concept.k2::after{background:var(--browser);}
.concept.k3::after{background:var(--agent);}
.concept.k4::after{background:var(--cross);}
.concept:hover{transform:translateY(-5px);border-color:#33364A;}
.concept .cn{font-family:'Inter';font-size:10.5px;font-weight:800;letter-spacing:.2em;}
.concept.k1 .cn{color:var(--local);}
.concept.k2 .cn{color:var(--browser);}
.concept.k3 .cn{color:var(--agent);}
.concept.k4 .cn{color:var(--cross);}
.concept b{display:block;font-size:15.5px;font-weight:800;margin-top:8px;}
.concept p{font-size:11.5px;color:var(--sub);margin-top:5px;line-height:1.7;}
/* marquee */
.marquee{overflow:hidden;white-space:nowrap;border-top:1px solid var(--line);border-bottom:1px solid var(--line);margin-top:80px;padding:18px 0;}
.mtrack{display:inline-block;animation:scroll 38s linear infinite;}
.mtrack span{font-family:'Inter';font-weight:900;font-size:52px;letter-spacing:-.02em;color:transparent;-webkit-text-stroke:1px #2E3147;padding-right:56px;}
.mtrack span b{color:var(--ink);-webkit-text-stroke:0;}
@keyframes scroll{to{transform:translateX(-50%)}}
/* ── section common ── */
section{max-width:1200px;margin:0 auto;padding:110px 28px;}
.ch-head{margin-bottom:54px;}
.ch-head .label{display:flex;align-items:center;gap:14px;font-family:'Inter';font-size:11px;font-weight:700;letter-spacing:.3em;margin-bottom:20px;}
.ch-head .label::before{content:"";width:42px;height:1px;background:currentColor;}
.ch-head .num{font-family:'Inter';font-weight:900;font-size:clamp(60px,10vw,120px);line-height:1;letter-spacing:-.04em;opacity:.14;display:block;margin-bottom:-22px;}
.ch-head h2{font-size:clamp(25px,4vw,42px);font-weight:900;line-height:1.45;}
.ch-head .def{margin-top:16px;color:var(--sub);font-size:13.5px;max-width:600px;}
.ch-head .def b{color:var(--ink);}
/* reveal */
.reveal{opacity:0;transform:translateY(40px);filter:blur(6px);transition:opacity .9s var(--ease),transform .9s var(--ease),filter .9s var(--ease);}
.reveal.on{opacity:1;transform:none;filter:none;}
.stagger>*{opacity:0;transform:translateY(30px);transition:opacity .7s var(--ease),transform .7s var(--ease);}
.stagger.on>*{opacity:1;transform:none;}
.stagger.on>*:nth-child(1){transition-delay:.04s}.stagger.on>*:nth-child(2){transition-delay:.12s}
.stagger.on>*:nth-child(3){transition-delay:.20s}.stagger.on>*:nth-child(4){transition-delay:.28s}
.stagger.on>*:nth-child(5){transition-delay:.36s}.stagger.on>*:nth-child(6){transition-delay:.44s}
/* tools row */
.tools{display:flex;flex-wrap:wrap;gap:10px;margin-bottom:36px;}
.tool{display:flex;align-items:center;gap:9px;border:1px solid var(--line);background:var(--panel);border-radius:99px;padding:8px 18px 8px 10px;font-family:'Inter','Noto Sans JP';font-weight:700;font-size:12.5px;transition:.3s var(--ease);}
.tool svg{width:22px;height:22px;}
.tool:hover{transform:translateY(-3px);border-color:#33364A;}
.tools-label{width:100%;font-family:'Inter';font-size:10px;font-weight:800;letter-spacing:.25em;color:var(--sub);margin-bottom:2px;}
/* case cards */
.cases{display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:16px;}
.case{border:1px solid var(--line);background:var(--panel);border-radius:22px;padding:28px 26px;transition:.4s var(--ease);position:relative;}
.case:hover{transform:translateY(-6px);}
.case .cn{font-family:'Inter';font-size:11px;font-weight:800;letter-spacing:.18em;opacity:.7;}
.case h3{font-size:16.5px;font-weight:900;line-height:1.6;margin:12px 0 10px;}
.case p{font-size:12px;color:var(--sub);line-height:1.85;}
.case .with{display:flex;flex-wrap:wrap;gap:6px;margin-top:16px;}
.case .with span{font-size:10.5px;font-weight:700;border:1px solid var(--line);border-radius:99px;padding:3px 11px;color:var(--sub);}
.s-local .case:hover{border-color:var(--local);}
.s-local .case .cn{color:var(--local);}
.s-browser .case:hover{border-color:var(--browser);}
.s-browser .case .cn{color:var(--browser);}
.s-agent .case:hover{border-color:var(--agent);}
.s-agent .case .cn{color:var(--agent);}
.s-cross .case:hover{border-color:var(--cross);}
.s-cross .case .cn{color:var(--cross);}
/* real case */
.real{margin-top:44px;border-radius:26px;padding:44px 40px;position:relative;overflow:hidden;border:1px solid var(--line);background:linear-gradient(135deg,var(--panel) 0%,var(--panel2) 100%);}
.real .rc-label{display:inline-flex;align-items:center;gap:10px;font-family:'Inter';font-size:10.5px;font-weight:800;letter-spacing:.25em;border:1px solid currentColor;border-radius:99px;padding:5px 16px;margin-bottom:24px;}
.s-local .real .rc-label{color:var(--local);}
.s-browser .real .rc-label{color:var(--browser);}
.s-agent .real .rc-label{color:var(--agent);}
.s-cross .real .rc-label{color:var(--cross);}
.real h3{font-size:clamp(17px,2.6vw,23px);font-weight:900;line-height:1.7;}
.real .body{margin-top:12px;font-size:12.5px;color:var(--sub);line-height:2;max-width:660px;}
.real .body b{color:var(--ink);}
.stats{display:grid;grid-template-columns:repeat(auto-fit,minmax(150px,1fr));gap:1px;background:var(--line);border:1px solid var(--line);border-radius:18px;overflow:hidden;margin-top:28px;}
.stat{background:var(--bg);padding:22px 20px;}
.stat .v{font-family:'Inter';font-weight:900;font-size:clamp(26px,3.6vw,40px);letter-spacing:-.03em;line-height:1.1;}
.s-local .stat .v{color:var(--local);}
.s-browser .stat .v{color:var(--browser);}
.s-agent .stat .v{color:var(--agent);}
.s-cross .stat .v{color:var(--cross);}
.stat .k{font-size:10.5px;color:var(--sub);font-weight:700;margin-top:6px;line-height:1.6;}
/* ── timeline ── */
.tl{position:relative;margin-top:30px;padding-left:30px;}
.tl::before{content:"";position:absolute;left:8px;top:8px;bottom:8px;width:1.5px;background:linear-gradient(180deg,var(--local),var(--browser),var(--agent),var(--cross));}
.tev{position:relative;padding:0 0 38px 34px;}
.tev:last-child{padding-bottom:0;}
.tev::before{content:"";position:absolute;left:-30px;top:8px;width:13px;height:13px;border-radius:50%;background:var(--bg);border:3px solid var(--agent);transform:translateX(2px);}
.tev:nth-child(1)::before{border-color:var(--local);}
.tev:nth-child(2)::before{border-color:var(--local);}
.tev:nth-child(3)::before{border-color:var(--browser);}
.tev:nth-child(4)::before{border-color:var(--agent);}
.tev:nth-child(5)::before{border-color:var(--cross);}
.tev:nth-child(6)::before{border-color:var(--cross);}
.tev .time{font-family:'Inter';font-weight:800;font-size:13px;letter-spacing:.1em;color:var(--sub);}
.tev b{display:block;font-size:15.5px;font-weight:900;margin-top:4px;}
.tev p{font-size:12px;color:var(--sub);margin-top:4px;line-height:1.85;max-width:560px;}
.tev .who{display:inline-block;margin-top:10px;font-family:'Inter';font-size:9.5px;font-weight:800;letter-spacing:.12em;border:1px solid var(--line);border-radius:99px;padding:2px 12px;color:var(--sub);}
/* ── closing ── */
.closing{text-align:center;padding-top:130px;padding-bottom:120px;}
.closing .en-huge{font-family:'Inter';font-weight:900;font-size:clamp(32px,6.6vw,80px);letter-spacing:-.03em;line-height:1.08;}
.closing .en-huge .grad{background:linear-gradient(92deg,var(--local),var(--browser),var(--agent),var(--cross));-webkit-background-clip:text;background-clip:text;color:transparent;}
.closing p{margin-top:28px;font-size:13.5px;font-weight:700;line-height:2.4;color:#C2C4D2;}
.closing p .key{color:var(--ink);border-bottom:2px solid var(--agent);}
.caution{max-width:660px;margin:46px auto 0;border:1px solid var(--line);border-radius:18px;padding:20px 26px;display:flex;gap:14px;align-items:flex-start;text-align:left;background:var(--panel);}
.caution svg.ic{color:#FFC555;margin-top:5px;}
.caution p{font-size:11.5px;color:var(--sub);line-height:1.9;margin:0;font-weight:500;}
footer{border-top:1px solid var(--line);padding:40px 28px 56px;color:#4E5060;font-size:10.5px;line-height:2.1;max-width:1200px;margin:0 auto;}
footer a{color:#6E7187;text-decoration:none;border-bottom:1px solid #33364A;}
footer .src{display:block;margin-top:10px;}
@media(max-width:760px){
  section{padding:70px 20px;}
  .hero{padding:76px 20px 40px;}
  .real{padding:30px 22px;}
}
</style>
</head>
