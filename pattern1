<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>WHICH AI, FOR WHICH WORK? — 4つのAIを「使い方」で選ぶ</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@500;700;800;900&family=Noto+Sans+JP:wght@400;500;700;900&display=swap" rel="stylesheet">
<style>
:root{
  --bg:#F7F7F4;
  --panel:#FFFFFF;
  --ink:#0E0E12;
  --sub:#74757D;
  --line:#E6E6E0;
  --blue:#2B3CFF;
  --claude:#D97757;
  --gpt:#10A37F;
  --gemini:#7B6FE0;
  --copilot:#3B82F6;
  --ease:cubic-bezier(.22,1,.36,1);
}
*{margin:0;padding:0;box-sizing:border-box;}
html{scroll-behavior:smooth;}
body{
  font-family:'Noto Sans JP',sans-serif;
  background:var(--bg);color:var(--ink);
  line-height:1.8;overflow-x:hidden;
  -webkit-font-smoothing:antialiased;
}
.en{font-family:'Inter','Noto Sans JP',sans-serif;letter-spacing:-.02em;}
svg.ic{width:22px;height:22px;fill:none;stroke:currentColor;stroke-width:1.8;stroke-linecap:round;stroke-linejoin:round;flex-shrink:0;}
/* ───── progress / nav ───── */
#progress{position:fixed;top:0;left:0;height:3px;width:0;z-index:999;background:var(--ink);transition:width .1s linear;}
nav{position:sticky;top:0;z-index:900;background:rgba(247,247,244,.85);backdrop-filter:blur(14px);border-bottom:1px solid var(--line);}
.nav-in{max-width:1200px;margin:0 auto;display:flex;align-items:center;gap:8px;padding:16px 28px;}
.nav-brand{font-family:'Inter';font-weight:800;font-size:13px;letter-spacing:.12em;margin-right:auto;}
nav a{color:var(--sub);text-decoration:none;font-size:11.5px;font-weight:700;letter-spacing:.08em;padding:6px 12px;border-radius:99px;transition:.3s var(--ease);}
nav a:hover{color:var(--ink);background:#ECECE6;}
@media(max-width:760px){nav a{display:none}}
/* ───── hero ───── */
.hero{position:relative;max-width:1200px;margin:0 auto;padding:110px 28px 40px;}
.hero .eyebrow{display:flex;align-items:center;gap:14px;font-family:'Inter';font-size:11px;font-weight:700;letter-spacing:.3em;color:var(--sub);margin-bottom:36px;}
.hero .eyebrow::before{content:"";width:42px;height:1px;background:var(--ink);}
.hero h1{font-family:'Inter';font-weight:900;font-size:clamp(46px,9.5vw,124px);line-height:1.0;letter-spacing:-.03em;}
.hero h1 .l2{display:block;background:linear-gradient(92deg,var(--claude) 0%,var(--gpt) 34%,var(--gemini) 67%,var(--copilot) 100%);-webkit-background-clip:text;background-clip:text;color:transparent;}
.hero .jp{margin-top:34px;font-size:clamp(14px,1.8vw,17px);font-weight:700;line-height:2.1;}
.hero .jp small{display:block;font-weight:400;color:var(--sub);font-size:.82em;margin-top:8px;}
.hero-logos{display:flex;gap:14px;margin-top:48px;flex-wrap:wrap;}
.hl{display:flex;align-items:center;gap:12px;background:var(--panel);border:1px solid var(--line);border-radius:99px;padding:10px 22px 10px 12px;font-family:'Inter';font-weight:700;font-size:13.5px;transition:.4s var(--ease);}
.hl svg{width:30px;height:30px;}
.hl:hover{transform:translateY(-4px);box-shadow:0 16px 32px rgba(14,14,18,.10);}
/* marquee */
.marquee{overflow:hidden;white-space:nowrap;border-top:1px solid var(--line);border-bottom:1px solid var(--line);margin-top:80px;padding:18px 0;}
.mtrack{display:inline-block;animation:scroll 36s linear infinite;}
.mtrack span{font-family:'Inter';font-weight:900;font-size:54px;letter-spacing:-.02em;color:transparent;-webkit-text-stroke:1px #C9C9C2;padding-right:56px;}
.mtrack span b{color:var(--ink);-webkit-text-stroke:0;font-weight:900;}
@keyframes scroll{to{transform:translateX(-50%)}}
/* ───── section common ───── */
section{max-width:1200px;margin:0 auto;padding:110px 28px;}
.sec-head{margin-bottom:56px;}
.eyebrow{display:flex;align-items:center;gap:14px;font-family:'Inter';font-size:11px;font-weight:700;letter-spacing:.3em;color:var(--blue);margin-bottom:20px;}
.eyebrow::before{content:"";width:42px;height:1px;background:var(--blue);}
.sec-head h2{font-size:clamp(26px,4.2vw,44px);font-weight:900;line-height:1.4;letter-spacing:.01em;}
.sec-head .sub{margin-top:16px;color:var(--sub);font-size:14px;max-width:560px;}
/* reveal */
.reveal{opacity:0;transform:translateY(40px);filter:blur(6px);transition:opacity .9s var(--ease),transform .9s var(--ease),filter .9s var(--ease);}
.reveal.on{opacity:1;transform:none;filter:none;}
.stagger>*{opacity:0;transform:translateY(30px);transition:opacity .7s var(--ease),transform .7s var(--ease);}
.stagger.on>*{opacity:1;transform:none;}
.stagger.on>*:nth-child(1){transition-delay:.04s}.stagger.on>*:nth-child(2){transition-delay:.10s}
.stagger.on>*:nth-child(3){transition-delay:.16s}.stagger.on>*:nth-child(4){transition-delay:.22s}
.stagger.on>*:nth-child(5){transition-delay:.28s}.stagger.on>*:nth-child(6){transition-delay:.34s}
.stagger.on>*:nth-child(7){transition-delay:.40s}.stagger.on>*:nth-child(8){transition-delay:.46s}
.stagger.on>*:nth-child(9){transition-delay:.52s}
/* ───── 01 axes ───── */
.axes{display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:1px;background:var(--line);border:1px solid var(--line);border-radius:24px;overflow:hidden;}
.axis{background:var(--panel);padding:34px 26px;transition:.4s var(--ease);}
.axis:hover{background:#FCFCF9;transform:scale(1.02);}
.axis .n{font-family:'Inter';font-size:11px;font-weight:700;color:#B9B9B2;letter-spacing:.15em;}
.axis svg.ic{width:26px;height:26px;margin:18px 0 14px;color:var(--ink);}
.axis h3{font-size:14.5px;font-weight:700;line-height:1.6;}
.axis p{font-size:11.5px;color:var(--sub);margin-top:6px;line-height:1.7;}
.thesis{margin-top:64px;text-align:center;font-weight:900;font-size:clamp(19px,3.2vw,30px);line-height:2;}
.thesis .strike{color:#C2C2BB;text-decoration:line-through;text-decoration-thickness:3px;}
.thesis .grad{background:linear-gradient(92deg,var(--claude),var(--gpt),var(--gemini),var(--copilot));-webkit-background-clip:text;background-clip:text;color:transparent;}
/* ───── 02 AI cards ───── */
.ai{background:var(--panel);border:1px solid var(--line);border-radius:28px;padding:44px 40px;margin-bottom:28px;position:relative;overflow:hidden;}
.ai::before{content:"";position:absolute;top:0;left:0;right:0;height:4px;}
.ai.claude::before{background:var(--claude);}
.ai.gpt::before{background:var(--gpt);}
.ai.gemini::before{background:linear-gradient(90deg,#4285F4,#9B72CB,#D96570);}
.ai.copilot::before{background:linear-gradient(90deg,#26C6DA,#3B82F6,#9333EA);}
.ai-top{display:flex;align-items:center;gap:20px;flex-wrap:wrap;margin-bottom:10px;}
.ai-top svg.logo{width:52px;height:52px;}
.ai-top h3{font-family:'Inter';font-size:30px;font-weight:800;letter-spacing:-.02em;}
.ai-top .en-tag{font-family:'Inter';font-size:11px;font-weight:700;letter-spacing:.22em;color:var(--sub);text-transform:uppercase;}
.ai-top .jp-tag{margin-left:auto;font-size:13px;font-weight:700;}
.ai.claude .jp-tag{color:var(--claude);}
.ai.gpt .jp-tag{color:var(--gpt);}
.ai.gemini .jp-tag{color:var(--gemini);}
.ai.copilot .jp-tag{color:var(--copilot);}
.feats{display:grid;grid-template-columns:repeat(auto-fill,minmax(255px,1fr));gap:14px;margin-top:26px;}
.feat{border:1px solid var(--line);border-radius:18px;padding:20px;transition:.35s var(--ease);}
.feat:hover{transform:translateY(-4px);}
.ai.claude .feat:hover{border-color:var(--claude);box-shadow:0 14px 28px rgba(217,119,87,.13);}
.ai.gpt .feat:hover{border-color:var(--gpt);box-shadow:0 14px 28px rgba(16,163,127,.13);}
.ai.gemini .feat:hover{border-color:var(--gemini);box-shadow:0 14px 28px rgba(123,111,224,.13);}
.ai.copilot .feat:hover{border-color:var(--copilot);box-shadow:0 14px 28px rgba(59,130,246,.13);}
.feat b{display:block;font-family:'Inter','Noto Sans JP';font-size:15px;font-weight:800;letter-spacing:-.01em;}
.feat p{font-size:12px;color:var(--sub);margin-top:5px;line-height:1.7;}
.chips{display:flex;flex-wrap:wrap;gap:6px;margin-top:12px;}
.chip{font-size:10.5px;font-weight:700;border-radius:99px;padding:3px 11px;}
.ai.claude .chip{background:#FAEEE8;color:#A85737;}
.ai.gpt .chip{background:#E5F4EF;color:#0A7C61;}
.ai.gemini .chip{background:#EEEcFB;color:#5B4EC9;}
.ai.copilot .chip{background:#E8F0FD;color:#2563C4;}
.note{margin-top:20px;font-size:11.5px;color:var(--sub);display:flex;gap:8px;align-items:flex-start;}
.note svg.ic{width:15px;height:15px;margin-top:4px;}
/* ───── 03 matrix ───── */
.matrix{background:var(--panel);border:1px solid var(--line);border-radius:24px;overflow:hidden;}
.mrow{display:grid;grid-template-columns:1fr repeat(4,76px);align-items:center;padding:0 10px 0 26px;border-bottom:1px solid var(--line);transition:.3s;}
.mrow:last-child{border-bottom:none;}
.mrow:not(.mhead):hover{background:#FBFBF7;}
.mhead{background:#FAFAF6;}
.mhead .mcell{padding:16px 0;display:flex;justify-content:center;}
.mhead svg{width:26px;height:26px;}
.mgoal{display:flex;align-items:center;gap:14px;padding:17px 0;font-size:13px;font-weight:700;}
.mgoal svg.ic{width:18px;height:18px;color:var(--sub);}
.mcell{display:flex;justify-content:center;}
.dot{width:13px;height:13px;border-radius:50%;}
.dot.c{background:var(--claude);}
.dot.g{background:var(--gpt);}
.dot.m{background:linear-gradient(135deg,#4285F4,#9B72CB);}
.dot.p{background:var(--copilot);}
.dot.off{width:5px;height:5px;background:#DDDDD6;}
.legend{display:flex;gap:22px;justify-content:flex-end;margin-top:14px;font-size:11px;color:var(--sub);font-weight:700;}
.legend i{display:inline-block;width:10px;height:10px;border-radius:50%;background:var(--ink);margin-right:6px;}
.legend i.off{width:5px;height:5px;background:#DDDDD6;vertical-align:2px;}
/* ───── 04 daily ───── */
.daily-wrap{display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:18px;}
.daily{background:var(--panel);border:1px solid var(--line);border-radius:22px;padding:28px 24px;transition:.4s var(--ease);}
.daily:hover{transform:translateY(-5px);box-shadow:0 18px 36px rgba(14,14,18,.08);}
.daily h3{display:flex;align-items:center;gap:10px;font-family:'Inter';font-size:17px;font-weight:800;margin-bottom:18px;}
.daily h3 svg{width:26px;height:26px;}
.daily ul{list-style:none;}
.daily li{display:flex;align-items:center;gap:10px;font-size:12.5px;font-weight:500;padding:8px 0;border-bottom:1px solid #F0F0EA;}
.daily li:last-child{border:none;}
.daily li svg.ic{width:14px;height:14px;}
.daily.claude li svg{color:var(--claude);}
.daily.gpt li svg{color:var(--gpt);}
.daily.gemini li svg{color:var(--gemini);}
.daily.copilot li svg{color:var(--copilot);}
.combo{margin-top:56px;background:var(--ink);color:#fff;border-radius:24px;padding:40px 36px;display:flex;align-items:center;gap:28px;flex-wrap:wrap;}
.combo .t{font-weight:900;font-size:clamp(16px,2.4vw,21px);line-height:1.9;}
.combo .flowmini{display:flex;align-items:center;gap:10px;font-family:'Inter';font-weight:700;font-size:12px;flex-wrap:wrap;margin-left:auto;}
.combo .step{border:1px solid rgba(255,255,255,.3);border-radius:99px;padding:7px 16px;}
.combo .step.s1{border-color:var(--gpt);color:#7FE0C8;}
.combo .step.s2{border-color:var(--claude);color:#F2B49C;}
.combo .step.s3{border-color:var(--copilot);color:#9DC2FB;}
.combo .ar{opacity:.5;}
/* ───── 05 automation ───── */
.flow{display:flex;align-items:stretch;gap:0;margin-top:20px;overflow-x:auto;padding-bottom:10px;}
.fstep{flex:1;min-width:150px;position:relative;padding:28px 18px 24px;border-left:1px solid var(--line);}
.fstep:first-child{border-left:none;}
.fstep .fn{font-family:'Inter';font-size:11px;font-weight:700;color:#B9B9B2;letter-spacing:.15em;}
.fstep .fico{width:52px;height:52px;border-radius:16px;background:var(--panel);border:1px solid var(--line);display:flex;align-items:center;justify-content:center;margin:16px 0 14px;}
.fstep .fico svg.ic{width:24px;height:24px;}
.fstep b{font-size:14px;font-weight:800;display:block;}
.fstep span{font-size:11px;color:var(--sub);display:block;margin-top:5px;line-height:1.7;}
.flow.on .fstep{animation:rise .7s var(--ease) backwards;}
.flow.on .fstep:nth-child(1){animation-delay:.05s}.flow.on .fstep:nth-child(2){animation-delay:.18s}
.flow.on .fstep:nth-child(3){animation-delay:.31s}.flow.on .fstep:nth-child(4){animation-delay:.44s}
.flow.on .fstep:nth-child(5){animation-delay:.57s}
@keyframes rise{from{opacity:0;transform:translateY(28px)}to{opacity:1;transform:none}}
.vision{margin-top:18px;font-size:11.5px;color:var(--sub);}
/* ladder */
.ladder{display:flex;align-items:flex-end;gap:12px;margin-top:48px;}
.rung{flex:1;border-radius:14px 14px 4px 4px;padding:18px 16px;display:flex;flex-direction:column;justify-content:flex-end;transition:.4s var(--ease);}
.rung:hover{transform:translateY(-6px);}
.rung .ln{font-family:'Inter';font-size:11px;font-weight:800;letter-spacing:.12em;opacity:.65;}
.rung b{font-size:13.5px;font-weight:800;margin-top:4px;}
.rung span{font-size:10.5px;margin-top:4px;opacity:.75;line-height:1.6;}
.rung.r1{height:120px;background:#E9EAF0;color:var(--ink);}
.rung.r2{height:160px;background:#CDD2F2;color:#23274E;}
.rung.r3{height:200px;background:#8C97E8;color:#fff;}
.rung.r4{height:240px;background:var(--blue);color:#fff;}
.ladder.on .rung{animation:rise .8s var(--ease) backwards;}
.ladder.on .rung:nth-child(1){animation-delay:.05s}.ladder.on .rung:nth-child(2){animation-delay:.2s}
.ladder.on .rung:nth-child(3){animation-delay:.35s}.ladder.on .rung:nth-child(4){animation-delay:.5s}
@media(max-width:680px){.ladder{flex-wrap:wrap}.rung{min-width:42%}}
/* ───── 06 summary ───── */
.summary{border-top:1px solid var(--line);padding-top:90px;}
.picks{display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:16px;margin-top:48px;}
.pick{background:var(--panel);border:1px solid var(--line);border-radius:22px;padding:30px 26px;transition:.4s var(--ease);}
.pick:hover{transform:translateY(-6px);box-shadow:0 20px 40px rgba(14,14,18,.09);}
.pick .q{font-size:13px;font-weight:700;line-height:1.8;min-height:66px;}
.pick .a{display:flex;align-items:center;gap:10px;margin-top:18px;font-family:'Inter';font-weight:800;font-size:18px;}
.pick .a svg{width:30px;height:30px;}
.pick .bar{height:3px;border-radius:2px;margin-top:16px;}
.closing{margin-top:90px;text-align:center;}
.closing .en-big{font-family:'Inter';font-weight:900;font-size:clamp(30px,6vw,68px);letter-spacing:-.03em;line-height:1.1;}
.closing .en-big .grad{background:linear-gradient(92deg,var(--claude),var(--gpt),var(--gemini),var(--copilot));-webkit-background-clip:text;background-clip:text;color:transparent;}
.closing p{margin-top:24px;font-size:14px;font-weight:700;color:var(--sub);}
footer{border-top:1px solid var(--line);text-align:center;padding:40px 28px 52px;color:#A3A39C;font-size:10.5px;line-height:2;}
@media(max-width:760px){
  section{padding:70px 20px;}
  .hero{padding:70px 20px 30px;}
  .mrow{grid-template-columns:1fr repeat(4,44px);padding-left:16px;}
  .ai{padding:30px 22px;}
}
</style>
</head>
